# MongoDB Connection (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/dragonsocial

# Change this to a long random string (minimum 32 characters)
SESSION_SECRET=super-long-random-secret-here-2026-change-this

# Optional but recommended for weather widget
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Port (default)
PORT=5050
